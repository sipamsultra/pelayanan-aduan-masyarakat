<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Aduan Masyarakat - Kanwil Ditjenpas</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --navy: #001f3f;
            --gold: #FFD700;
            --grey: #f4f4f4;
        }
        .bg-navy { background-color: var(--navy); }
        .text-navy { color: var(--navy); }
        .bg-gold { background-color: var(--gold); }
        .border-gold { border-color: var(--gold); }
        .text-gold { color: var(--gold); }
    </style>
</head>
<body class="bg-gray-100 font-sans text-gray-800">

    <!-- Navigation -->
    <nav class="bg-navy text-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <div class="w-10 h-10 bg-gold rounded-full flex items-center justify-center text-navy font-bold">K</div>
                <span class="font-bold text-lg hidden md:block">E-ADUAN KANWIL SULTRA</span>
            </div>
            <div class="space-x-4 text-sm font-medium">
                <button onclick="showPage('beranda')" class="hover:text-gold transition">Beranda</button>
                <button onclick="showPage('tentang')" class="hover:text-gold transition">Tentang</button>
                <button onclick="showPage('form')" class="hover:text-gold transition">Buat Aduan</button>
                <button onclick="showPage('status')" class="hover:text-gold transition">Cek Status</button>
                <button onclick="showPage('admin-login')" class="bg-gold text-navy px-3 py-1 rounded hover:bg-yellow-500 transition">Admin</button>
            </div>
        </div>
    </nav>

    <!-- Content Sections -->
    <main class="container mx-auto px-4 py-8 min-h-screen">
        
        <!-- Beranda -->
        <section id="beranda" class="page-content">
            <div class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col md:flex-row">
                <div class="p-8 md:w-1/2 flex flex-col justify-center">
                    <h1 class="text-4xl font-bold text-navy mb-4">Layanan Pengaduan Masyarakat Online</h1>
                    <p class="text-gray-600 mb-6">Sampaikan keluhan Anda secara langsung kepada instansi yang berwenang dengan cepat, mudah, dan transparan.</p>
                    <div class="flex space-x-3">
                        <button onclick="showPage('form')" class="bg-navy text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-900 transition shadow-lg">Mulai Lapor</button>
                        <button onclick="showPage('tentang')" class="border border-navy text-navy px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">Pelajari Lebih Lanjut</button>
                    </div>
                </div>
                <div class="md:w-1/2 bg-gray-200 h-64 md:h-auto flex items-center justify-center">
                    <i class="fas fa-bullhorn text-9xl text-navy opacity-20"></i>
                </div>
            </div>
        </section>

        <!-- Tentang -->
        <section id="tentang" class="page-content hidden">
            <div class="bg-white p-8 rounded-xl shadow-md border-t-4 border-gold">
                <h2 class="text-3xl font-bold text-navy mb-6">Tentang E-Aduan</h2>
                <p class="mb-4">Sistem ini dirancang untuk memudahkan masyarakat dalam memberikan masukan, kritik, dan pengaduan terkait pelayanan di lingkungan Kantor Wilayah Direktorat Jenderal Pemasyarakatan Sulawesi Tenggara dan Unit Pelaksana Teknis (UPT) di bawahnya.</p>
                <div class="grid md:grid-cols-3 gap-6 mt-8">
                    <div class="p-4 bg-gray-50 rounded-lg text-center">
                        <i class="fas fa-shield-alt text-3xl text-gold mb-3"></i>
                        <h4 class="font-bold">Privasi Terjaga</h4>
                        <p class="text-sm">Data pribadi Anda aman dalam sistem kami.</p>
                    </div>
                    <div class="p-4 bg-gray-50 rounded-lg text-center">
                        <i class="fas fa-bolt text-3xl text-gold mb-3"></i>
                        <h4 class="font-bold">Respon Cepat</h4>
                        <p class="text-sm">Tim kami akan memproses aduan sesegera mungkin.</p>
                    </div>
                    <div class="p-4 bg-gray-50 rounded-lg text-center">
                        <i class="fas fa-envelope-open-text text-3xl text-gold mb-3"></i>
                        <h4 class="font-bold">Email Notifikasi</h4>
                        <p class="text-sm">Update status dikirim langsung ke email Anda.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Form Aduan -->
        <section id="form" class="page-content hidden">
            <div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-lg border-t-4 border-gold">
                <h2 class="text-2xl font-bold text-navy mb-6 text-center">Formulir Pengaduan</h2>
                <form id="aduanForm" class="space-y-4">
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold mb-1">Nama Lengkap</label>
                            <input type="text" id="nama" required class="w-full p-2 border rounded focus:ring-2 focus:ring-navy outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-1">No. HP (WhatsApp)</label>
                            <input type="tel" id="nohp" required class="w-full p-2 border rounded focus:ring-2 focus:ring-navy outline-none">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-1">Email Aktif</label>
                        <input type="email" id="email" required class="w-full p-2 border rounded focus:ring-2 focus:ring-navy outline-none">
                        <p class="text-xs text-gray-500 mt-1">*Umpan balik akan dikirim ke email ini.</p>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-1">Pilih UPT</label>
                        <select id="upt" required class="w-full p-2 border rounded focus:ring-2 focus:ring-navy outline-none">
                            <option value="">-- Pilih Unit Layanan --</option>
                            <option>Kanwil Ditjenpas</option>
                            <option>Lapas Kendari</option>
                            <option>Lapas Bau-bau</option>
                            <option>Lapas Perempuan</option>
                            <option>Lapas Khusus Anak</option>
                            <option>Bapas Kendari</option>
                            <option>Bapas Bau-bau</option>
                            <option>Rutan Kendari</option>
                            <option>Rutan Unaaha</option>
                            <option>Rutan Kolaka</option>
                            <option>Rutan Raha</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-1">Jenis Aduan</label>
                        <div class="flex space-x-4">
                            <label class="flex items-center"><input type="radio" name="jenis" value="Pelayanan" checked class="mr-2"> Pelayanan</label>
                            <label class="flex items-center"><input type="radio" name="jenis" value="Pegawai" class="mr-2"> Pegawai</label>
                            <label class="flex items-center"><input type="radio" name="jenis" value="Lainnya" class="mr-2"> Lainnya</label>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-1">Isi Aduan</label>
                        <textarea id="isi" required rows="4" class="w-full p-2 border rounded focus:ring-2 focus:ring-navy outline-none" placeholder="Jelaskan detail kejadian..."></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-1">Upload Foto (Base64/Link)</label>
                        <input type="text" id="foto" class="w-full p-2 border rounded focus:ring-2 focus:ring-navy outline-none" placeholder="Link foto atau biarkan kosong">
                    </div>
                    <button type="submit" id="btnSubmit" class="w-full bg-navy text-white py-3 rounded-lg font-bold hover:bg-blue-900 shadow-md">Kirim Pengaduan</button>
                </form>
            </div>
        </section>

        <!-- Status Aduan -->
        <section id="status" class="page-content hidden">
            <div class="max-w-3xl mx-auto bg-white p-8 rounded-xl shadow-md">
                <h2 class="text-2xl font-bold text-navy mb-6">Cek Status Aduan</h2>
                <div class="flex space-x-2 mb-8">
                    <input type="text" id="searchId" placeholder="Masukkan ID Aduan (Contoh: ADU-12345)" class="flex-1 p-2 border rounded">
                    <button onclick="checkStatus()" class="bg-gold text-navy px-6 py-2 rounded font-bold">Cari</button>
                </div>
                <div id="statusResult" class="hidden border rounded-lg p-6 bg-gray-50">
                    <!-- Dinamis -->
                </div>
            </div>
        </section>

        <!-- Admin Login -->
        <section id="admin-login" class="page-content hidden">
            <div class="max-w-md mx-auto bg-white p-8 rounded-xl shadow-lg border-t-4 border-navy">
                <h2 class="text-2xl font-bold text-navy mb-6 text-center">Login Admin</h2>
                <div class="space-y-4">
                    <input type="password" id="adminPass" placeholder="Masukkan Password" class="w-full p-2 border rounded">
                    <button onclick="loginAdmin()" class="w-full bg-navy text-white py-2 rounded font-bold">Masuk</button>
                </div>
            </div>
        </section>

        <!-- Admin Dashboard -->
        <section id="admin-dashboard" class="page-content hidden">
            <div class="bg-white p-6 rounded-xl shadow-lg">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-navy">Data Aduan Masuk</h2>
                    <button onclick="logoutAdmin()" class="text-red-600 font-bold">Logout</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-gray-100 border-b">
                            <tr>
                                <th class="p-3">ID / Tanggal</th>
                                <th class="p-3">Pelapor</th>
                                <th class="p-3">UPT / Jenis</th>
                                <th class="p-3">Status</th>
                                <th class="p-3">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="adminTableBody">
                            <!-- Dinamis -->
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

    <!-- Modal Admin Update -->
    <div id="adminModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-[100]">
        <div class="bg-white rounded-lg p-6 w-full max-w-md">
            <h3 class="text-xl font-bold mb-4">Update Status Aduan</h3>
            <input type="hidden" id="modalId">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm mb-1 font-bold">Ubah Status</label>
                    <select id="modalStatus" class="w-full p-2 border rounded">
                        <option>Diproses</option>
                        <option>Selesai</option>
                        <option>Ditolak</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm mb-1 font-bold">Keterangan / Balasan</label>
                    <textarea id="modalKet" class="w-full p-2 border rounded" rows="3"></textarea>
                </div>
                <div class="flex space-x-2">
                    <button onclick="closeModal()" class="flex-1 py-2 border rounded">Batal</button>
                    <button onclick="saveAdminUpdate()" class="flex-1 py-2 bg-navy text-white rounded">Simpan & Kirim Email</button>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-navy text-white py-8 mt-12">
        <div class="container mx-auto px-4 text-center">
            <p>&copy; 2026 Kanwil Ditjenpas Sulawesi Tenggara. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        // CONFIGURATION
        const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyq39bdpPlIPUkaZMpE3jbn_QvilfeEPt29WRSh7iq8R8FwaJQkXPdWijbJtlTJ4VI/exec';
        const ADMIN_PASSWORD = 'admin123';

        let allData = [];

        function showPage(pageId) {
            document.querySelectorAll('.page-content').forEach(p => p.classList.add('hidden'));
            document.getElementById(pageId).classList.remove('hidden');
            window.scrollTo(0,0);
        }

        // Form Aduan Submission
        document.getElementById('aduanForm').onsubmit = async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerText = "Mengirim...";

            const payload = {
                action: 'submitAduan',
                nama: document.getElementById('nama').value,
                nohp: document.getElementById('nohp').value,
                email: document.getElementById('email').value,
                upt: document.getElementById('upt').value,
                jenis: document.querySelector('input[name="jenis"]:checked').value,
                isi: document.getElementById('isi').value,
                foto: document.getElementById('foto').value
            };

            try {
                const response = await fetch(SCRIPT_URL, {
                    method: 'POST',
                    body: JSON.stringify(payload)
                });
                const result = await response.json();
                if(result.result === 'success') {
                    alert('Aduan Berhasil Dikirim! Simpan ID Anda: ' + result.id);
                    document.getElementById('aduanForm').reset();
                    showPage('beranda');
                }
            } catch (err) {
                alert('Gagal mengirim aduan. Pastikan SCRIPT_URL sudah benar.');
            } finally {
                btn.disabled = false;
                btn.innerText = "Kirim Pengaduan";
            }
        };

        // Cek Status
        async function checkStatus() {
            const id = document.getElementById('searchId').value.trim();
            if(!id) return;
            
            const resultDiv = document.getElementById('statusResult');
            resultDiv.innerHTML = "Mencari data...";
            resultDiv.classList.remove('hidden');

            try {
                const response = await fetch(SCRIPT_URL);
                const data = await response.json();
                const found = data.find(item => item.id.toLowerCase() === id.toLowerCase());

                if(found) {
                    resultDiv.innerHTML = `
                        <div class="flex justify-between items-start mb-4">
                            <h4 class="font-bold text-navy">Hasil Temuan:</h4>
                            <span class="px-3 py-1 rounded-full text-xs font-bold ${getStatusClass(found.status)} text-white">${found.status}</span>
                        </div>
                        <div class="grid grid-cols-2 gap-2 text-sm">
                            <p class="text-gray-500">ID:</p><p class="font-medium">${found.id}</p>
                            <p class="text-gray-500">Tanggal:</p><p class="font-medium">${new Date(found.tanggal).toLocaleDateString()}</p>
                            <p class="text-gray-500">UPT:</p><p class="font-medium">${found.upt}</p>
                            <p class="text-gray-500">Isi:</p><p class="font-medium italic">"${found.isi}"</p>
                            <p class="text-gray-500">Balasan Admin:</p><p class="font-bold text-blue-700">${found.keterangan || '-'}</p>
                        </div>
                    `;
                } else {
                    resultDiv.innerHTML = "<p class='text-red-500'>ID Aduan tidak ditemukan.</p>";
                }
            } catch (err) {
                resultDiv.innerHTML = "<p class='text-red-500'>Gagal mengambil data.</p>";
            }
        }

        // Admin Logic
        function loginAdmin() {
            if(document.getElementById('adminPass').value === ADMIN_PASSWORD) {
                showPage('admin-dashboard');
                loadAdminData();
            } else {
                alert('Password Salah!');
            }
        }

        function logoutAdmin() {
            document.getElementById('adminPass').value = '';
            showPage('beranda');
        }

        async function loadAdminData() {
            const tbody = document.getElementById('adminTableBody');
            tbody.innerHTML = "<tr><td colspan='5' class='p-4 text-center'>Memuat data...</td></tr>";
            
            try {
                const response = await fetch(SCRIPT_URL);
                allData = await response.json();
                tbody.innerHTML = "";
                
                allData.reverse().forEach(item => {
                    const row = `
                        <tr class="border-b hover:bg-gray-50">
                            <td class="p-3">
                                <p class="font-bold">${item.id}</p>
                                <p class="text-xs text-gray-400">${new Date(item.tanggal).toLocaleString()}</p>
                            </td>
                            <td class="p-3">
                                <p>${item.nama}</p>
                                <p class="text-xs text-blue-600">${item.email}</p>
                            </td>
                            <td class="p-3">
                                <p class="font-medium">${item.upt}</p>
                                <p class="text-xs italic">${item.jenis}</p>
                            </td>
                            <td class="p-3">
                                <span class="px-2 py-1 rounded text-[10px] uppercase font-bold ${getStatusClass(item.status)} text-white">${item.status}</span>
                            </td>
                            <td class="p-3">
                                <button onclick="openAdminModal('${item.id}', '${item.status}', '${item.keterangan}')" class="text-navy hover:underline font-bold">Edit</button>
                            </td>
                        </tr>
                    `;
                    tbody.innerHTML += row;
                });
            } catch (err) {
                tbody.innerHTML = "<tr><td colspan='5' class='p-4 text-red-500'>Gagal memuat data.</td></tr>";
            }
        }

        function getStatusClass(status) {
            if(status === 'Diproses') return 'bg-blue-500';
            if(status === 'Selesai') return 'bg-green-500';
            if(status === 'Ditolak') return 'bg-red-500';
            return 'bg-yellow-500';
        }

        // Modal Update
        function openAdminModal(id, status, ket) {
            document.getElementById('modalId').value = id;
            document.getElementById('modalStatus').value = status === 'Menunggu' ? 'Diproses' : status;
            document.getElementById('modalKet').value = ket || '';
            document.getElementById('adminModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('adminModal').classList.add('hidden');
        }

        async function saveAdminUpdate() {
            const id = document.getElementById('modalId').value;
            const status = document.getElementById('modalStatus').value;
            const keterangan = document.getElementById('modalKet').value;

            const btn = document.querySelector('#adminModal button:last-child');
            btn.innerText = "Proses...";
            btn.disabled = true;

            try {
                await fetch(SCRIPT_URL, {
                    method: 'POST',
                    body: JSON.stringify({
                        action: 'updateStatus',
                        id, status, keterangan
                    })
                });
                alert('Update Berhasil & Email Terkirim!');
                closeModal();
                loadAdminData();
            } catch (err) {
                alert('Gagal update.');
            } finally {
                btn.innerText = "Simpan & Kirim Email";
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
